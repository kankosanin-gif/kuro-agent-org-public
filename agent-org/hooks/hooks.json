{
  "hooks": [
    {
      "id": "dirty-working-tree",
      "enabled": true,
      "when": {
        "type": "contains",
        "file": "agent-org/reports/hourly-status.md",
        "text": "Git Working Tree"
      },
      "if_any": [
        " M ",
        "?? "
      ],
      "action": {
        "type": "append_markdown",
        "file": "agent-org/reports/action-queue.md",
        "title": "Working tree has pending changes",
        "body": "Create or update task contracts for pending changes and classify by manager owner."
      }
    },
    {
      "id": "warn-topline",
      "enabled": true,
      "when": {
        "type": "contains",
        "file": "agent-org/reports/hourly-status.md",
        "text": "Topline: **WARN"
      },
      "action": {
        "type": "append_markdown",
        "file": "agent-org/reports/action-queue.md",
        "title": "Topline WARN detected",
        "body": "Escalate to relevant manager and record blocker in weekly review format."
      }
    }
  ]
}
